---
import { Image } from "astro:assets";
import { getEntry, render } from "astro:content";
import { marked } from "marked";
import presentation from "../../../../assets/presentation.svg";
import Input from "../../../../components/input.astro";
import Select from "../../../../components/select.astro";
import Textarea from "../../../../components/textarea.astro";
import Layout from "../../../../layouts/espanol.astro";

const page = await getEntry("pages", "request");
const content = page?.data && marked.parse(page.data.content_es);
---

<Layout>
  <main class="h-full p-8 md:p-16 pb-0! flex flex-col gap-32">
    <section class="size-full flex flex-wrap justify-center items-center gap-8">
      <div class="w-md">
        <h1>{page?.data.heading_es}</h1>
        <Fragment set:html={content} />
      </div>
      <Image
        src={presentation}
        alt={page?.data.photoAltText_es || null}
        class="w-full max-w-md"
      />
    </section>
    <section
      class="w-[calc(100% + 2rem)] bg-secondary px-8 md:px-16 py-32 -mx-8 md:-mx-16 text-white"
    >
      <h1 class="text-center mb-16!">La información</h1>
      <div class="flex flex-wrap items-start justify-center gap-16">
        <form id="form" class="w-xs flex flex-col items-end text-black!">
          <input
            type="hidden"
            name="access_key"
            value="e28d4ed9-e67d-4fc3-b246-b0aebf5d9243"
          />
          <Input
            name="name"
            label="Nombre"
            placeholder="Juana Pérez"
            required
          />
          <Input
            type="email"
            name="email"
            label="Correo electrónico"
            placeholder="juana.perez@gmail.com"
            required
          />
          <Select
            name="attendance"
            label="Asistencia Esperada"
            placeholder="Estoy esperando..."
            options={[
              "5 a 50 personas",
              "51-200 personas",
              "200+ personas",
              "No estoy seguro...",
            ]}
            required
          />
          <Select
            name="committment"
            label="Tiempo Requerido"
            placeholder="Debería tomar aproximadamente..."
            options={[
              "10-15 minutos",
              "30-60 minutos",
              "1-2 horas",
              "3+ horas",
              "No estoy seguro...",
            ]}
            required
          />
          <Input
            name="date-time"
            label="Fecha/Hora"
            placeholder="1/1/11, 1pm"
            required
          />
          <Textarea
            name="details"
            label="Detalles"
            placeholder="Bueno, aquí están los detalles..."
            required
          />
          <button id="submit-button" type="submit" class="btn btn-accent mt-4"
            >Enviar</button
          >
          <div id="result"></div>
        </form>
        <div class="min-w-3xs w-lg max-w-full">
          <h2>Envíeme los detalles.</h2>
          <p class="font-light">
            ¡Tengo muchas ganas de asistir y conectar con su comunidad! Pero
            necesito conocer algunos detalles específicos para poder planearlo
            bien. Por favor, comparta los detalles conmigo en este formulario.
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const form = document.getElementById("form") as HTMLFormElement;
  const submitButton = document.getElementById("submit-button") as HTMLElement;
  const result = document.getElementById("result") as HTMLElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    submitButton.innerHTML = "Enviando...";

    const response = await fetch("https://api.web3forms.com/submit", {
      method: "POST",
      body: new FormData(form),
    });

    const data = await response.json();
    if (data.success) {
      window.location.href = "/es/thank-you";
    } else {
      result.innerHTML = data.message;
    }
    window.posthog?.capture("contact_form_submitted");
  });
</script>
