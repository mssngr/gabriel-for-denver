---
import { Image } from "astro:assets";
import { getEntry, render } from "astro:content";
import { marked } from "marked";
import presentation from "../../../assets/presentation.svg";
import Input from "../../../components/input.astro";
import Select from "../../../components/select.astro";
import Textarea from "../../../components/textarea.astro";
import Layout from "../../../layouts/default.astro";

const page = await getEntry("pages", "request");
const content = marked.parse(page.data?.content);
---

<Layout>
  <main class="h-full p-8 md:p-16 pb-0! flex flex-col gap-32">
    <section class="size-full flex flex-wrap justify-center items-center gap-8">
      <div class="w-md">
        <h1>{page.data.heading}</h1>
        <Fragment set:html={content} />
      </div>
      <Image
        src={presentation}
        alt={page.data.photoAltText}
        class="w-full max-w-md"
      />
    </section>
    <section
      class="w-[calc(100% + 2rem)] bg-secondary px-8 md:px-16 py-32 -mx-8 md:-mx-16 text-white"
    >
      <h1 class="text-center mb-16!">The info</h1>
      <div class="flex flex-wrap items-start justify-center gap-16">
        <form id="form" class="w-xs flex flex-col items-end text-black!">
          <input
            type="hidden"
            name="access_key"
            value="e28d4ed9-e67d-4fc3-b246-b0aebf5d9243"
          />
          <Input name="name" label="Name" placeholder="Jane Doe" required />
          <Input
            type="email"
            name="email"
            label="Email"
            placeholder="jane.doe@gmail.com"
            required
          />
          <Select
            name="attendance"
            label="Expected Attendance"
            placeholder="I am expecting..."
            options={[
              "5 to 50 people",
              "51-200 people",
              "200+ people",
              "Unsure...",
            ]}
            required
          />
          <Select
            name="committment"
            label="Time Committment"
            placeholder="It should take about..."
            options={[
              "10-15 minutes",
              "30-60 minutes",
              "1-2 hours",
              "3+ hours",
              "Unsure...",
            ]}
            required
          />
          <Input
            name="date-time"
            label="Date/Time"
            placeholder="1/1/11, 1pm"
            required
          />
          <Textarea
            name="details"
            label="Details"
            placeholder="So, here's the details..."
            required
          />
          <button id="submit-button" type="submit" class="btn btn-accent mt-4"
            >Send</button
          >
        </form>
        <div class="min-w-3xs w-lg max-w-full">
          <h2>Send the deets.</h2>
          <p class="font-light">
            I'm really looking forward to showing up and connecting with your
            community! But, I need to know some specifics to really plan it out.
            Please share the particulars with me on this form.
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const form = document.getElementById("form") as HTMLFormElement;
  const submitButton = document.getElementById("submit-button") as HTMLElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    submitButton.innerHTML = "Sending...";

    const response = await fetch("https://api.web3forms.com/submit", {
      method: "POST",
      body: new FormData(form),
    });

    const data = await response.json();
    if (data.success) {
      window.location.href = "/thank-you";
    } else {
      result.innerHTML = data.message;
    }
    window.posthog?.capture("contact_form_submitted");
  });
</script>
