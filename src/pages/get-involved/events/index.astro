---
import { Image } from "astro:assets";
import { getEntry, render } from "astro:content";
import { marked } from "marked";
import chainLogo from "../../../assets/chainlogo.webp";
import events from "../../../assets/events.svg";
import ContactForm from "../../../components/contact-form.astro";
import WhatWillITackle from "../../../components/what-will-i-tackle.astro";
import Layout from "../../../layouts/default.astro";

const page = await getEntry("pages", "events");
const content = marked.parse(page.data?.content);
---

<Layout>
  <main class="h-full p-8 md:p-16 pb-0! flex flex-col gap-32">
    <section class="size-full flex flex-wrap justify-center items-center gap-8">
      <div class="w-md [&_a]:link">
        <h1>{page.data.heading}</h1>
        <Fragment set:html={content} />
      </div>
      <Image
        src={events}
        alt={page.data.photoAltText}
        class="w-full max-w-md"
      />
    </section>
    <section
      class="w-[calc(100% + 2rem)] bg-secondary px-8 md:px-16 py-32 -mx-8 md:-mx-16 text-white"
    >
      <h1 class="text-center mb-16!">Where I'm going to be</h1>
      <div class="flex flex-wrap items-center justify-center gap-16">
        <Image
          src={chainLogo}
          alt="Chain Reaction Brewing Co logo"
          class="flex-1 max-w-48"
        />
        <div class="flex-1 max-w-2xl">
          <h2>Campaign Kickoff</h2>
          <p>Chain Reaction Brewing Co.</p>
          <h3>8/8/26, 5:00pm</h3>
          <p class="font-light mt-4">
            We are kicking off our campaign with beer, signatures, and music!
            Help us kick it off right and get a head start on getting on that
            ballot!
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>
