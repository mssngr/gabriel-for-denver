---
import { Image } from "astro:assets";
import {
  Apple,
  ArrowRight,
  CalendarDays,
  Coins,
  DatabaseZap,
  HandCoins,
  HouseHeart,
  MapPinHouse,
  MessageCircle,
  Siren,
  Users,
} from "@lucide/astro";
import logoDesktop from "../assets/gfd-banner.svg";
import logoMobile from "../assets/gfd-mobile-banner.svg";

const currentPath = Astro.url.pathname;
---

<div
  class="w-full h-40 md:h-56 p-4 md:px-16 md:py-8 flex items-center justify-between"
>
  <a class="w-32 h-32 md:w-fit md:h-44 shrink-0" href="/es"
    ><Image
      class="md:hidden"
      src={logoMobile}
      alt="Logo that reads 'Gabriel for Denver'"
    /><Image
      class="max-md:hidden w-fit h-full"
      src={logoDesktop}
      alt="Logo that reads 'Gabriel for Denver'"
    /></a
  >
  <div>
    <ul
      class="ml-6 menu menu-horizontal px-1 text-lg md:text-2xl font-semibold"
    >
      <li>
        <details>
          <summary
            class={`md:text-2xl ${currentPath.includes("/issues") ? "text-primary font-black" : ""}`}
            >Retos de Denver</summary
          >
          <ul class="bg-base-100 rounded-t-none p-2 z-10">
            <li>
              <a
                href="/es/issues/affordability"
                class={`${currentPath.includes("/es/issues/affordability") ? "text-primary font-black" : ""}`}
                ><Coins />Asequibilidad</a
              >
            </li>
            <li>
              <a
                href="/es/issues/housing-crisis"
                class={`${currentPath.includes("/es/issues/housing-crisis") ? "text-primary font-black" : ""}`}
                ><MapPinHouse />Crisis de Vivienda</a
              >
            </li>
            <li>
              <a
                href="/es/issues/criminal-injustice"
                class={`${currentPath.includes("/es/issues/criminal-injustice") ? "text-primary font-black" : ""}`}
                ><Siren />Injusticia Penal</a
              >
            </li>
            <li>
              <a
                href="/es/issues/food-security"
                class={`${currentPath.includes("/es/issues/food-security") ? "text-primary font-black" : ""}`}
                ><Apple />Seguridad Alimentaria</a
              >
            </li>
            <li>
              <a
                href="/es/issues/homelessness"
                class={`${currentPath.includes("/es/issues/homelessness") ? "text-primary font-black" : ""}`}
                ><HouseHeart />Personas sin Hogar</a
              >
            </li>
            <li>
              <a
                href="/es/issues/big-tech"
                class={`${currentPath.includes("/es/issues/big-tech") ? "text-primary font-black" : ""}`}
                ><DatabaseZap />Grandes Tecnológicas</a
              >
            </li>
            <li>
              <a href="/es/issues" class="inline-flex items-center"
                >Ver Todos <ArrowRight class="size-4" /></a
              >
            </li>
          </ul>
        </details>
      </li>
      <li>
        <a
          class={`md:text-2xl ${currentPath.includes("/es/why-me") ? "text-primary font-black" : ""}`}
          href="/es/why-me">¿Por qué yo?</a
        >
      </li>
      <li>
        <details>
          <summary
            class={`md:text-2xl ${currentPath.includes("/es/get-involved") ? "text-primary font-black" : ""}`}
            >Involúcrate</summary
          >
          <ul class="bg-base-100 rounded-t-none p-2 z-10">
            <li>
              <a
                href="/es/get-involved/events"
                class={`${currentPath.includes("/es/get-involved/events") ? "text-primary font-black" : ""}`}
                ><CalendarDays />Eventos</a
              >
            </li>
            <li>
              <a
                href="/es/get-involved/donate"
                class={`${currentPath.includes("/es/get-involved/donate") ? "text-primary font-black" : ""}`}
                ><HandCoins />Donar</a
              >
            </li>
            <li>
              <a
                href="/es/get-involved/volunteer"
                class={`${currentPath.includes("/es/get-involved/volunteer") ? "text-primary font-black" : ""}`}
                ><Users />Voluntario</a
              >
            </li>
            <li>
              <a
                href="/es/get-involved/contact-me"
                class={`${currentPath.includes("/es/get-involved/contact-me") ? "text-primary font-black" : ""}`}
                ><MessageCircle />Contáctanos</a
              >
            </li>
          </ul>
        </details>
      </li>
    </ul>
  </div>
  <a
    href={currentPath.replace("/es", "") || "/"}
    class="link mt-4 md:mt-0"
    id="lang-switch-en">English</a
  >
</div>

<script is:inline>
  document
    .getElementById("lang-switch-en")
    ?.addEventListener("click", function () {
      window.posthog?.capture("language_switched", { to: "en" });
    });
</script>
