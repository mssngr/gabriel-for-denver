---
import { Image } from "astro:assets";
import {
  Apple,
  ArrowRight,
  CalendarDays,
  Coins,
  DatabaseZap,
  HandCoins,
  HouseHeart,
  MapPinHouse,
  MessageCircle,
  Siren,
  Users,
} from "@lucide/astro";
import { Astro } from "astro";
import logoDesktop from "../assets/gfd-banner.svg";
import logoMobile from "../assets/gfd-mobile-banner.svg";

const currentPath = Astro.url.pathname;
---

<div
  class="w-full h-40 md:h-56 p-4 md:px-16 md:py-8 flex items-center justify-between"
>
  <a class="w-32 h-32 md:w-fit md:h-44 shrink-0" href="/"
    ><Image
      class="md:hidden"
      src={logoMobile}
      alt="Logo that reads 'Gabriel for Denver'"
    /><Image
      class="max-md:hidden w-fit h-full"
      src={logoDesktop}
      alt="Logo that reads 'Gabriel for Denver'"
    /></a
  >
  <div>
    <ul
      class="ml-2 menu menu-horizontal px-1 text-lg md:text-2xl font-semibold"
    >
      <li>
        <details>
          <summary
            class={`md:text-2xl ${currentPath.includes("/issues/") ? "text-primary font-black" : ""}`}
            >Issues Denver faces</summary
          >
          <ul class="bg-base-100 rounded-t-none p-2 z-10">
            <li>
              <a
                href="/issues/affordability"
                class={`${currentPath === "/issues/affordability" ? "text-primary font-black" : ""}`}
                ><Coins />Affordability</a
              >
            </li>
            <li>
              <a
                href="/issues/housing-crisis"
                class={`${currentPath === "/issues/housing-crisis" ? "text-primary font-black" : ""}`}
                ><MapPinHouse />Housing Crisis</a
              >
            </li>
            <li>
              <a
                href="/issues/criminal-injustice"
                class={`${currentPath === "/issues/criminal-injustice" ? "text-primary font-black" : ""}`}
                ><Siren />Criminal Injustice</a
              >
            </li>
            <li>
              <a
                href="/issues/food-security"
                class={`${currentPath === "/issues/food-security" ? "text-primary font-black" : ""}`}
                ><Apple />Food Security</a
              >
            </li>
            <li>
              <a
                href="/issues/homelessness"
                class={`${currentPath === "/issues/homelessness" ? "text-primary font-black" : ""}`}
                ><HouseHeart />Homelessness</a
              >
            </li>
            <li>
              <a
                href="/issues/big-tech"
                class={`${currentPath === "/issues/big-tech" ? "text-primary font-black" : ""}`}
                ><DatabaseZap />Big Tech</a
              >
            </li>
            <li>
              <a href="/issues" class="inline-flex items-center"
                >See All <ArrowRight class="size-4" /></a
              >
            </li>
          </ul>
        </details>
      </li>
      <li>
        <a
          class={`md:text-2xl ${currentPath === "/why-me" ? "text-primary font-black" : ""}`}
          href="/why-me">Why me?</a
        >
      </li>
      <li>
        <details>
          <summary
            class={`md:text-2xl ${currentPath.includes("/get-involved/") ? "text-primary font-black" : ""}`}
            >Get involved</summary
          >
          <ul class="bg-base-100 rounded-t-none p-2 z-10">
            <li>
              <a
                href="/get-involved/events"
                class={`${currentPath.includes("/get-involved/events") ? "text-primary font-black" : ""}`}
                ><CalendarDays />Events</a
              >
            </li>
            <li>
              <a
                href="/get-involved/donate"
                class={`${currentPath === "/get-involved/donate" ? "text-primary font-black" : ""}`}
                ><HandCoins />Donate</a
              >
            </li>
            <li>
              <a
                href="/get-involved/volunteer"
                class={`${currentPath === "/get-involved/volunteer" ? "text-primary font-black" : ""}`}
                ><Users />Volunteer</a
              >
            </li>
            <li>
              <a
                href="/get-involved/contact-me"
                class={`${currentPath === "/get-involved/contact-me" ? "text-primary font-black" : ""}`}
                ><MessageCircle />Contact Me</a
              >
            </li>
          </ul>
        </details>
      </li>
    </ul>
  </div>
  <a href={`/es${currentPath}`} class="link" id="lang-switch-es">Español</a>
</div>

<script is:inline>
  document
    .getElementById("lang-switch-es")
    ?.addEventListener("click", function () {
      window.posthog?.capture("language_switched", { to: "es" });
    });
</script>
