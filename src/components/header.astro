---
import { Image } from "astro:assets";
import {
  Apple,
  ArrowRight,
  Coins,
  DatabaseZap,
  HouseHeart,
  MapPinHouse,
  Siren,
} from "@lucide/astro";
import logoDesktop from "../assets/gfd-banner.svg";
import logoMobile from "../assets/gfd-mobile-banner.svg";
---

<div
  class="w-full h-40 md:h-56 p-4 md:px-16 md:py-8 flex items-center justify-between"
>
  <a class="w-32 h-32 md:w-fit md:h-44 shrink-0" href="/"
    ><Image
      class="md:hidden"
      src={logoMobile}
      alt="Logo that reads 'Gabriel for Denver'"
    /><Image
      class="max-md:hidden w-fit h-full"
      src={logoDesktop}
      alt="Logo that reads 'Gabriel for Denver'"
    /></a
  >
  <div>
    <ul
      class="ml-2 menu menu-horizontal px-1 text-lg md:text-2xl font-semibold"
    >
      <li>
        <details>
          <summary class="md:text-2xl">Issues Denver faces</summary>
          <ul class="bg-base-100 rounded-t-none p-2 z-10">
            <li>
              <a href="/issues/affordability"><Coins />Affordability</a>
            </li>
            <li>
              <a href="/issues/housing-crisis"><MapPinHouse />Housing Crisis</a>
            </li>
            <li>
              <a href="/issues/criminal-injustice"
                ><Siren />Criminal Injustice</a>
            </li>
            <li><a href="/issues/food-security"><Apple />Food Security</a></li>
            <li>
              <a href="/issues/homelessness"><HouseHeart />Homelessness</a>
            </li>
            <li><a href="/issues/big-tech"><DatabaseZap />Big Tech</a></li>
            <li>
              <a href="/issues" class="inline-flex items-center"
                >See All <ArrowRight class="size-4" /></a
              >
            </li>
          </ul>
        </details>
      </li>
      <li><a class="md:text-2xl" href="/why-me">Why me?</a></li>
      <li>
        <a class="md:text-2xl" href="/#get-involved">Get involved</a>
      </li>
    </ul>
  </div>
  <a href="/es" class="link">Español</a>
</div>
